// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

// Connection URL is configured in prisma.config.ts (Prisma 7 requirement).
datasource db {
  provider = "sqlite"
}

model Entry {
  id        String   @id @default(cuid())
  date      DateTime // UTC midnight of the local calendar day
  type      String   @default("DAILY") // "DAILY" | "WEEKLY" | "MONTHLY" | "YEARLY"
  content   String // Free-text body
  prompts   String? // JSON: [{prompt: string, answer: string}]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([date])
  @@index([type])
}

model MoodLog {
  id        String   @id @default(cuid())
  date      DateTime // UTC midnight of the local calendar day — unique per day
  score     Int // 1–10
  note      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([date])
  @@index([date])
}

model Review {
  id        String   @id @default(cuid())
  type      String   // "WEEKLY" | "MONTHLY" | "YEARLY"
  periodKey String   // "2026-W09" | "2026-03" | "2026"
  sections  String   // JSON: [{prompt: string, answer: string}]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([type, periodKey]) // one review per period
  @@index([type, periodKey])
}

model Goal {
  id         String        @id @default(cuid())
  title      String
  why        String? // motivation / context
  targetDate DateTime? // UTC midnight, optional
  status     String        @default("ACTIVE") // "ACTIVE" | "PAUSED" | "COMPLETED"
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  checkins   GoalCheckin[]

  @@index([status])
}

model GoalCheckin {
  id         String   @id @default(cuid())
  goalId     String
  note       String
  confidence Int? // 1–5, optional
  createdAt  DateTime @default(now())
  goal       Goal     @relation(fields: [goalId], references: [id], onDelete: Cascade)

  @@index([goalId])
}

model Affirmation {
  id          String   @id @default(cuid())
  text        String   @unique
  isFavourite Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isFavourite])
}
